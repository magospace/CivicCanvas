# Public runtime label shown in the header and /api/health.
NEXT_PUBLIC_APP_ENV=hosted-beta

# Public release/version label shown in the header, /api/health, and saved-canvas bundle metadata.
NEXT_PUBLIC_APP_VERSION=v1.3.0-hosted-launch-readiness

# Optional public deployment URL used only for /api/health metadata and smoke-test expectations.
# NEXT_PUBLIC_SITE_URL=https://your-public-beta.example

# Optional server-side OpenAI provider key for prompt-assist interpretation and source-aware summaries.
# Keep real values in .env.local or hosting secrets only. Never expose this as NEXT_PUBLIC_*.
OPENAI_API_KEY=

# VERCEL*, GITHUB_SHA, and GITHUB_REF_NAME are read from the hosting or CI runtime when present.
